{
  "name": "first-tree",
  "version": "0.3.1-alpha",
  "description": "CLI for Context Tree onboarding, GitHub Scan automation, and hub workflows.",
  "keywords": [
    "agents",
    "cli",
    "context-tree",
    "first-tree",
    "github"
  ],
  "homepage": "https://github.com/agent-team-foundation/first-tree#readme",
  "bugs": {
